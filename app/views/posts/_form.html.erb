<%= form_with model: post do |form| %>
  <% if post.errors.any? %>
    <section class="error-box">
      <h3>Не удалось сохранить пост</h3>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <div class="field">
    <%= form.label :title, "Название" %>
    <%= form.text_field :title, maxlength: 120, placeholder: "Можно оставить пустым — возьмем из видео" %>
  </div>

  <div class="field">
    <%= form.label :description, "Описание" %>
    <%= form.text_area :description, rows: 5, maxlength: 5000 %>
  </div>

  <div class="field">
    <%= form.label :video, "Видео" %>
    <%= form.file_field :video, required: post.new_record?, accept: ".mp4,.webm,.mov,.mkv,video/mp4,video/webm,video/quicktime,video/x-matroska" %>
    <small>
      Поддерживаются современные кодеки: AV1, H.265/HEVC, VP9 и H.264.
      Сервер проверяет кодек через ffprobe.
    </small>
    <% if post.video.attached? %>
      <small>Текущее видео сохранено. Выберите файл только если хотите заменить его.</small>
    <% end %>
  </div>

  <%= form.submit(post.new_record? ? "Опубликовать" : "Сохранить изменения", class: "button") %>
<% end %>
