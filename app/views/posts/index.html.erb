<section class="page-head page-head--filters">
  <nav class="topic-filters" aria-label="Фильтр по тематике">
    <%= link_to "Все",
                root_path(q: @query.presence),
                class: [ "post-tag", "post-tag--filter", ("post-tag--active" if @selected_tag.blank?) ] %>
    <% Post::ALLOWED_TAGS.each do |tag| %>
      <%= link_to tag,
                  root_path(q: @query.presence, tag:),
                  class: [ "post-tag", "post-tag--filter", ("post-tag--active" if @selected_tag == tag) ] %>
    <% end %>
  </nav>

  <% if @query.present? %>
    <p class="search-summary search-summary--right">
      Результаты поиска: <strong><%= @query %></strong>
    </p>
  <% end %>
</section>

<% if @posts.any? %>
  <section class="posts-grid">
    <% @posts.each do |post| %>
      <article class="post-card">
        <% if post.video.attached? %>
          <div class="post-card-media">
            <%= link_to post_path(post), class: "preview-link" do %>
              <% if post.list_preview_image.present? %>
                <%= image_tag post.list_preview_image,
                              class: "video video-preview",
                              alt: "Превью для #{post.title}",
                              loading: "lazy" %>
              <% else %>
                <div class="video video-placeholder">
                  <span>Превью создается...</span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <h2><%= link_to post.title, post_path(post), class: "post-card__title-link", title: post.title %></h2>

        <p class="post-meta">
          Автор: <%= post.user&.display_name || "удаленный пользователь" %> •
          Опубликовано <%= l(post.created_at, format: :short) %>
        </p>
        <p class="post-meta">
          Комментариев: <%= post.comments.size %>
        </p>

        <div class="post-tags">
          <% post.tag_list.each do |tag| %>
            <%= link_to "##{tag}", root_path(tag:), class: "post-tag" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </section>
<% else %>
  <section class="panel">
    <% if @query.present? %>
      <p class="empty">По запросу ничего не найдено.</p>
    <% else %>
      <p class="empty">Пока нет постов. Создайте первый видео-пост.</p>
    <% end %>
  </section>
<% end %>
