<section class="page-head">
  <h1>Лента видео</h1>
  <% if @query.present? %>
    <p class="search-summary">Результаты поиска: <strong><%= @query %></strong></p>
  <% end %>
</section>

<% if @posts.any? %>
  <section class="posts-grid">
    <% @posts.each do |post| %>
      <article class="post-card">
        <% if post.video.attached? %>
          <div class="post-card-media">
            <%= link_to post_path(post), class: "preview-link" do %>
              <% if post.thumbnail.attached? %>
                <%= image_tag post.thumbnail,
                              class: "video video-preview",
                              alt: "Превью для #{post.title}",
                              loading: "lazy" %>
              <% else %>
                <div class="video video-placeholder">
                  <span>Превью создается...</span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <h2><%= link_to post.title, post_path(post) %></h2>

        <% if post.description.present? %>
          <p><%= truncate(post.description, length: 220) %></p>
        <% end %>

        <p class="post-meta">
          Опубликовано <%= l(post.created_at, format: :short) %> •
          Комментариев: <%= post.comments.size %>
        </p>

        <%= render "reactions", post:, user_reaction: @user_reactions_by_post_id[post.id] %>
      </article>
    <% end %>
  </section>
<% else %>
  <section class="panel">
    <% if @query.present? %>
      <p class="empty">По запросу ничего не найдено.</p>
    <% else %>
      <p class="empty">Пока нет постов. Создайте первый видео-пост.</p>
    <% end %>
  </section>
<% end %>
