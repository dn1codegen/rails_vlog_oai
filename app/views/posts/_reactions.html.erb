<div class="reaction-bar">
  <% if user_signed_in? %>
    <div class="reaction-actions">
      <% like_classes = [ "button", "button--secondary", "button--small" ] %>
      <% like_classes << "reaction-button--active" if user_reaction&.kind == "like" %>
      <% dislike_classes = [ "button", "button--secondary", "button--small" ] %>
      <% dislike_classes << "reaction-button--active" if user_reaction&.kind == "dislike" %>

      <%= button_to post_reaction_path(post, kind: "like"),
                    method: :post,
                    class: [ *like_classes, "reaction-icon-button" ].join(" "),
                    form: { class: "inline-form" },
                    "aria-label": "Понравилось (#{post.likes_count})" do %>
        <svg class="reaction-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 10v10M7 10l5-8h2v6h5l-1 12h-8V10z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round" />
        </svg>
        <span class="reaction-value"><%= post.likes_count %></span>
      <% end %>
      <%= button_to post_reaction_path(post, kind: "dislike"),
                    method: :post,
                    class: [ *dislike_classes, "reaction-icon-button" ].join(" "),
                    form: { class: "inline-form" },
                    "aria-label": "Не понравилось (#{post.dislikes_count})" do %>
        <svg class="reaction-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 14V4M7 14l5 8h2v-6h5L18 4h-8v10z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round" />
        </svg>
        <span class="reaction-value"><%= post.dislikes_count %></span>
      <% end %>
    </div>
  <% else %>
    <div class="reaction-counts">
      <span class="reaction-count">
        <svg class="reaction-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 10v10M7 10l5-8h2v6h5l-1 12h-8V10z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round" />
        </svg>
        <strong><%= post.likes_count %></strong>
      </span>
      <span class="reaction-count">
        <svg class="reaction-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 14V4M7 14l5 8h2v-6h5L18 4h-8v10z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round" />
        </svg>
        <strong><%= post.dislikes_count %></strong>
      </span>
    </div>
    <p class="reaction-login-hint">
      <%= link_to "Войдите", new_session_path %>, чтобы оценить пост.
    </p>
  <% end %>
</div>
