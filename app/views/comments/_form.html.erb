<%= form_with model: [post, comment] do |form| %>
  <% if user_signed_in? %>
    <p class="post-meta">Комментарий будет опубликован от: <strong><%= current_user.display_name %></strong></p>
  <% end %>

  <div class="field">
    <%= form.label :body, "Комментарий" %>
    <%= form.text_area :body, rows: 4, required: true, maxlength: 1000 %>
  </div>

  <%= form.submit submit_label, class: "button" %>
<% end %>
