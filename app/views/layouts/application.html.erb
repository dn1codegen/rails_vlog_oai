<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Openai" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Openai">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <nav class="top-menu" aria-label="Основное меню">
          <div class="top-menu__left">
            <%= link_to root_path, class: "site-brand" do %>
              <span class="site-brand__badge" aria-hidden="true">▶</span>
              <span class="site-brand__text">MediaTUBE</span>
            <% end %>
          </div>
          <%= form_with url: root_path, method: :get, local: true, class: "top-menu__search", role: "search" do |f| %>
            <%= f.search_field :q,
                               value: params[:q],
                               placeholder: "Поиск по постам",
                               class: "top-menu__search-input",
                               "aria-label": "Поиск по постам" %>
            <%= f.submit "НАЙТИ", class: "top-menu__search-button" %>
          <% end %>
          <div class="top-menu__right">
            <% if user_signed_in? %>
              <%= link_to "СОЗДАТЬ ПОСТ", new_post_path, class: "top-menu__link" %>
              <details class="account-menu">
                <summary class="account-menu__summary" aria-label="Аккаунт">
                  <span class="account-menu__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" role="presentation" focusable="false">
                      <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>
                      <path d="M4 20c0-3.314 3.582-6 8-6s8 2.686 8 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                    </svg>
                  </span>
                </summary>
                <div class="account-menu__dropdown">
                  <%= link_to "ПРОФИЛЬ", profile_path, class: "account-menu__item" %>
                  <%= button_to "ВЫЙТИ", session_path,
                                method: :delete,
                                class: "account-menu__item account-menu__item--button",
                                form: { class: "account-menu__form" } %>
                </div>
              </details>
            <% else %>
              <%= link_to "ВОЙТИ", new_session_path, class: "top-menu__link" %>
              <%= link_to "РЕГИСТРАЦИЯ", new_registration_path, class: "top-menu__link" %>
            <% end %>
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <% flash.each do |name, message| %>
        <p class="flash flash--<%= name %>"><%= message %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
