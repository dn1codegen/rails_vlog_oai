<section class="page-head">
  <h1>Регистрация</h1>
  <%= link_to "Назад к ленте", root_path, class: "button button--secondary" %>
</section>

<section class="panel">
  <%= form_with model: @user, url: registration_path do |form| %>
    <% if @user.errors.any? %>
      <section class="error-box">
        <h3>Не удалось зарегистрироваться</h3>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <div class="field">
      <%= form.label :email, "Email" %>
      <%= form.email_field :email, required: true, autocomplete: "email" %>
    </div>

    <div class="field">
      <%= form.label :password, "Пароль" %>
      <%= form.password_field :password, required: true, minlength: 8, autocomplete: "new-password" %>
    </div>

    <div class="field">
      <%= form.label :password_confirmation, "Подтверждение пароля" %>
      <%= form.password_field :password_confirmation, required: true, minlength: 8, autocomplete: "new-password" %>
    </div>

    <%= form.submit "Зарегистрироваться", class: "button" %>
  <% end %>

  <p class="post-meta">
    Уже есть аккаунт?
    <%= link_to "Войти", new_session_path %>
  </p>
</section>
