<section class="page-head">
  <h1>Профиль</h1>
  <%= link_to "Редактировать профиль", edit_profile_path, class: "button button--secondary" %>
</section>

<section class="panel profile-card">
  <h2 class="profile-card__title"><%= @user.display_name %></h2>
  <p class="post-meta">Email: <%= @user.email %></p>

  <% if @user.bio.present? %>
    <div class="profile-bio"><%= simple_format(@user.bio) %></div>
  <% else %>
    <p class="empty">Расскажите о себе в разделе редактирования профиля.</p>
  <% end %>

  <div class="profile-stats">
    <article class="profile-stat">
      <strong><%= @posts_count %></strong>
      <span>Постов</span>
    </article>
    <article class="profile-stat">
      <strong><%= @user.comments.count %></strong>
      <span>Комментариев</span>
    </article>
    <article class="profile-stat">
      <strong><%= @user.post_reactions.count %></strong>
      <span>Реакций</span>
    </article>
  </div>
</section>

<section class="panel profile-archive-panel">
  <h2>Экспорт и импорт архива</h2>
  <p class="profile-archive-panel__hint">
    Скачайте ZIP-архив со своими видео и файлом <code>posts.json</code>, либо загрузите архив такого же формата.
  </p>

  <div class="profile-archive-panel__actions">
    <%= link_to "Скачать архив моих видео", export_videos_profile_path, class: "button" %>

    <%= form_with url: import_videos_profile_path, method: :post, html: { multipart: true }, class: "profile-import-form" do %>
      <label for="archive_file">Импорт из ZIP-архива</label>
      <%= file_field_tag :archive, id: "archive_file", accept: ".zip,application/zip", required: true %>
      <%= submit_tag "Импортировать архив", class: "button button--secondary" %>
    <% end %>
  </div>
</section>

<section class="panel">
  <h2>Мои видео (<%= @posts_count %>)</h2>

  <% if @profile_posts.any? %>
    <div class="profile-bulk-actions">
      <%= form_with url: destroy_selected_posts_profile_path,
                    method: :delete,
                    id: "profile-bulk-delete-form",
                    class: "profile-bulk-delete-form" do %>
        <%= hidden_field_tag :page, @current_page %>
        <%= submit_tag "Удалить выбранные", class: "button button--danger button--small", data: { turbo_confirm: "Удалить выбранные посты?" } %>
      <% end %>
      <%= form_with url: destroy_all_posts_profile_path, method: :delete, class: "profile-bulk-delete-form" do %>
        <%= submit_tag "Удалить все посты", class: "button button--danger button--small", data: { turbo_confirm: "Удалить все ваши посты?" } %>
      <% end %>
    </div>

    <div class="profile-posts">
      <% @profile_posts.each_with_index do |post, index| %>
        <% post_number = @post_number_offset + index + 1 %>
        <% visibility_label = post.visibility_private_post? ? "Личный" : "Публичный" %>
        <% toggle_visibility = post.visibility_private_post? ? "public_post" : "private_post" %>
        <% toggle_action_label = post.visibility_private_post? ? "Сделать пост публичным" : "Сделать пост личным" %>
        <article class="profile-post">
          <div class="profile-post__head">
            <div class="profile-post__title-wrap">
              <label class="profile-post__selector">
                <%= check_box_tag "post_ids[]",
                                  post.id,
                                  false,
                                  id: "profile_post_select_#{post.id}",
                                  form: "profile-bulk-delete-form",
                                  class: "profile-post__checkbox" %>
                <span class="profile-post__number">№<%= post_number %></span>
              </label>
              <h3><%= link_to post.title, post_path(post) %></h3>
            </div>
            <div class="profile-post__controls">
              <%= form_with url: profile_post_visibility_path(post), method: :patch, class: "profile-visibility-form" do %>
                <%= hidden_field_tag :visibility, toggle_visibility %>
                <%= hidden_field_tag :page, @current_page %>
                <button type="submit"
                        class="profile-visibility-switch <%= "is-private" if post.visibility_private_post? %>"
                        aria-label="<%= toggle_action_label %>">
                  <span class="profile-visibility-switch__text"><%= visibility_label %></span>
                  <span class="profile-visibility-switch__track" aria-hidden="true">
                    <span class="profile-visibility-switch__thumb"></span>
                  </span>
                </button>
              <% end %>
              <div class="profile-post__actions">
                <%= link_to "Редактировать", edit_post_path(post), class: "button button--secondary button--small" %>
                <%= button_to "Удалить",
                              post_path(post),
                              method: :delete,
                              params: { from_profile: true, page: @current_page },
                              class: "button button--danger button--small",
                              form: { class: "profile-post-delete-form", data: { turbo_confirm: "Удалить этот пост?" } } %>
              </div>
            </div>
          </div>
          <p class="profile-post__meta">
            <%= l(post.created_at, format: :short) %> •
            Комментариев: <%= post.comments.size %>
          </p>
        </article>
      <% end %>
    </div>

    <% if @total_pages > 1 %>
      <nav class="profile-pagination" aria-label="Пагинация постов">
        <% if @current_page > 1 %>
          <%= link_to "Назад", profile_path(page: @current_page - 1), class: "button button--secondary button--small" %>
        <% end %>
        <span class="profile-pagination__info">Страница <%= @current_page %> из <%= @total_pages %></span>
        <% if @current_page < @total_pages %>
          <%= link_to "Вперед", profile_path(page: @current_page + 1), class: "button button--secondary button--small" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <p class="empty">Вы пока не опубликовали ни одного видео.</p>
  <% end %>
</section>
